// OpenClaw OS - Hierarchical schema
// Multi-company, org charts, heartbeats, goals, cost tracking

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// COMPANY MODEL - Multi-tenant isolation
// ============================================================================

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  agents    Agent[]
  goals     Goal[]
  tasks     Task[]
  sessions  Session[]

  @@map("companies")
}

// ============================================================================
// AGENT MODEL - Org chart with reporting lines
// ============================================================================

model Agent {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  title       String?  // e.g., "Chief Technology Officer"
  role        String   // e.g., "cto", "dev", "qa"
  enabled     Boolean  @default(true)

  // Org chart - who reports to whom
  reportsToId String?
  reportsTo   Agent?   @relation("AgentHierarchy", fields: [reportsToId], references: [id])
  reports     Agent[]  @relation("AgentHierarchy")

  // Heartbeat scheduling
  heartbeatEnabled    Boolean   @default(false)
  heartbeatIntervalMs Int       @default(60000) // 1 minute default
  lastHeartbeatAt     DateTime?
  heartbeatStatus     String    @default("idle") // idle, running, error

  // Adapter config (process, http, openclaw)
  adapterType         String    @default("openclaw") // openclaw, process, http
  adapterConfig       String?   // JSON blob for adapter-specific config

  // Cost tracking
  monthlyBudgetUsd    Float?
  spentUsd            Float     @default(0)
  budgetPeriod        String    @default("monthly")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company  @relation(fields: [companyId], references: [id])
  tasks     Task[]
  sessions  Session[]

  @@index([companyId])
  @@index([reportsToId])
  @@map("agents")
}

// ============================================================================
// GOAL MODEL - Hierarchy: Initiative → Project → Milestone → Issue
// ============================================================================

model Goal {
  id          String   @id @default(uuid())
  companyId   String
  parentId    String?
  parent      Goal?    @relation("GoalHierarchy", fields: [parentId], references: [id])
  children    Goal[]   @relation("GoalHierarchy")

  title       String
  description String?
  level       String   @default("project") // initiative, project, milestone, issue
  status      String   @default("active")  // active, completed, paused, cancelled

  // Progress tracking
  progressPercent Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company Company @relation(fields: [companyId], references: [id])
  tasks   Task[]

  @@index([companyId])
  @@index([parentId])
  @@map("goals")
}

// ============================================================================
// TASK MODEL - Work items with goal alignment
// ============================================================================

model Task {
  id          String   @id @default(uuid())
  companyId   String
  goalId      String?

  title       String
  description String?
  status      String   @default("todo") // todo, in_progress, review, done, blocked
  priority    String   @default("P2")   // P0, P1, P2, P3
  area        String?  // backend, frontend, devops, qa

  // Assignment
  ownerId     String?
  owner       Agent?   @relation(fields: [ownerId], references: [id])

  // Cost tracking
  inputTokens  Int     @default(0)
  outputTokens Int     @default(0)
  costUsd      Float   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  startedAt DateTime?
  doneAt    DateTime?

  // Relations
  company Company @relation(fields: [companyId], references: [id])
  goal    Goal?   @relation(fields: [goalId], references: [id])

  @@index([companyId])
  @@index([goalId])
  @@index([ownerId])
  @@index([status])
  @@map("tasks")
}

// ============================================================================
// SESSION MODEL - Agent execution history
// ============================================================================

model Session {
  id          String   @id @default(uuid())
  companyId   String
  agentId     String

  key         String   @unique // Session key
  kind        String?  // chat, heartbeat, manual
  status      String   @default("active") // active, completed, aborted

  // Token usage
  inputTokens  Int     @default(0)
  outputTokens Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  endedAt   DateTime?

  // Relations
  company Company @relation(fields: [companyId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])

  @@index([companyId])
  @@index([agentId])
  @@map("sessions")
}
